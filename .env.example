# Container timezone — ใช้กำหนดเวลาของ cron schedule
TZ=Asia/Bangkok

# DAILY flow: fundamental data (dividend, financials, valuation ฯลฯ)
RUN_HOUR=8
RUN_MINUTE=0

# INTRADAY flow: market movers, premarket, after-hours
# INTRADAY_HOUR_1 = หลัง US after-hours จบ (04:00 BKK)
# INTRADAY_HOUR_2 = ช่วง US market open (22:00 BKK)
INTRADAY_HOUR_1=4
INTRADAY_HOUR_2=22

# Prefect home directory (เก็บ metadata ใน volume เดียวกับ data)
PREFECT_HOME=/data/prefect

# (Optional) Prefect Cloud / self-hosted server
# ถ้าไม่ใส่ = ใช้ temporary local server (default)
# Cloud:       https://api.prefect.cloud/api/accounts/<ACCOUNT_ID>/workspaces/<WORKSPACE_ID>
# Self-hosted: http://prefect-server:4200/api
# PREFECT_API_URL=
# PREFECT_API_KEY=

# จำนวนวันที่เก็บ partition ย้อนหลัง ก่อนลบอัตโนมัติ
RETENTION_DAYS=90

# Timezone สำหรับ cron schedule (default: Asia/Bangkok)
# SCHEDULE_TZ=Asia/Bangkok

# จำนวน API ที่ fetch พร้อมกันสูงสุด (default: 5)
# MAX_CONCURRENT=5

# Alert webhook — ส่ง notification เมื่อมี DQ warning หรือ API fail
# รองรับ Discord, Slack หรือ webhook ทั่วไป ถ้าไม่ใส่จะไม่ส่ง
# Discord: https://discord.com/api/webhooks/xxxx/yyyy
# Slack:   https://hooks.slack.com/services/xxxx/yyyy/zzzz
ALERT_WEBHOOK_URL=

# Heartbeat — ส่ง success notification ทุกครั้งที่ pipeline รันสำเร็จ
# เพื่อให้รู้ว่า pipeline ยัง alive (default: false — แจ้งแค่ตอน fail)
# ALERT_ON_SUCCESS=true

# Weekend check — INTRADAY mode จะ skip วันเสาร์-อาทิตย์ (US market ปิด)
# ตั้ง true เพื่อข้าม check นี้ สำหรับ testing หรือ backfill
# SKIP_WEEKEND_CHECK=false